# Normalize line endings: store text as LF in the repo, let Git handle
# checkout conversion per-OS. This silences the CRLF warnings on Windows.
* text=auto eol=lf

# Explicitly treat known text types as text
*.java   text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.json   text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.properties text eol=lf
Dockerfile   text eol=lf

# Binary types Git should never touch
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.mv.db binary
